# AWS Configuration
aws_region  = "us-east-1"
environment = "dev"

# Instance Configuration - Cheapest options:
# t4g.small = $0.0168/hour (~$12.60/month) - ARM64/Graviton (RECOMMENDED - best value)
# t3.small  = $0.0208/hour (~$15.60/month) - x86_64 (if you need x86 compatibility)
instance_type = "t4g.small"

# Model Provider Configuration
model_provider   = "bedrock"              # Options: "bedrock" (default) or "openrouter"
bedrock_model_id = "us.amazon.nova-2-lite-v1:0"

# Optional: Bedrock model tuning (defaults work for amazon.nova-lite-v1:0)
bedrock_context_window = 1000000
bedrock_max_tokens     = 8192

# Optional: Switch to a reasoning model like DeepSeek R1
# Some models require an inference profile ID (us. prefix) -- see Runbook.md
# bedrock_model_id       = "us.deepseek.r1-v1:0"
# bedrock_context_window = 128000
# bedrock_max_tokens     = 8192

# Optional: OpenRouter (set key in SSM first, see Runbook.md)
# model_provider           = "openrouter"
# openrouter_model_id      = "openai/gpt-4o-mini"
# openrouter_ssm_parameter = "/openclaw/dev/openrouter-api-key"
# Then run once:
#   aws ssm put-parameter --name "/openclaw/dev/openrouter-api-key" \
#     --type SecureString --value "sk-or-v1-..." --region us-east-1

# VPC Endpoints - Disabled by default to save ~$22/month
# Enable for production (private SSM/Bedrock access, compliance)
enable_vpc_endpoints = false

# EBS volume - set to false to preserve data on instance termination
# (orphaned volumes incur charges)
# delete_ebs_on_termination = true

# Optional: Additional tags
tags = {
  Owner = "your-name"
  Team  = "platform"
}
